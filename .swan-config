# Swift WASM SDK configuration for 6.3 release
WASM_SDK=swift-6.3-RELEASE_wasm
WASM_SDK_URL=https://download.swift.org/swift-6.3-release/wasm-sdk/swift-6.3-RELEASE/swift-6.3-RELEASE_wasm.artifactbundle.tar.gz
WASM_SDK_CHECKSUM=9fa4016ee632c7e9e906608ec3b55cf13dfc4dff44e47574c5af58064dc33fd9

# Embedded WASM requires a main-branch snapshot toolchain due to a Swift 6.3
# compiler limitation with SPI conformances in embedded mode.
CI_TC_VERSION_EMBEDDED=main-snapshot-2026-03-09
WASM_SDK_EMBEDDED=swift-DEVELOPMENT-SNAPSHOT-2026-03-09-a_wasm-embedded
WASM_SDK_URL_EMBEDDED=https://download.swift.org/development/wasm-sdk/swift-DEVELOPMENT-SNAPSHOT-2026-03-09-a/swift-DEVELOPMENT-SNAPSHOT-2026-03-09-a_wasm.artifactbundle.tar.gz
WASM_SDK_CHECKSUM_EMBEDDED=37defbeca856ab15377411c3c47881132ec03f614f036223feef6b0280ce0a54
