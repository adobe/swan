{
  "name": "swan",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "config": {
    "swift_sdk_wasm": "swift-6.3-DEVELOPMENT-SNAPSHOT-2026-02-14-a_wasm"
  },
  "scripts": {
    "swift-setup": "swiftly install && swiftly use",
    "build": "swift build",
    "build:release": "swift build -c release",
    "wasm:build": "BUILD_WASM=1 swift build --target WebGPU --swift-sdk $npm_package_config_swift_sdk_wasm",
    "wasm:build:bridgejs": "BUILD_WASM=1 swift package plugin --allow-writing-to-package-directory bridge-js",
    "wasm:demo:bitonic": "BUILD_WASM=1 swift package --swift-sdk $npm_package_config_swift_sdk_wasm js --product BitonicSort && pnpx serve .",
    "test": "swift test",
    "generate:apinotes": "swift package --allow-writing-to-package-directory generate-dawn-apinotes",
    "demo:gameoflife": "swift run GameOfLife",
    "demo:bitonic": "swift run BitonicSort",
    "format": "swift format --in-place --recursive Sources Tests Demos",
    "clean": "swift package clean",
    "resolve": "swift package resolve"
  },
  "dependencies": {
    "typescript": "5.9.3"
  }
}
